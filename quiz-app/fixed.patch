+        reader.onloadend = () => {
+          resolve({
+            name: `pasted-image-${Date.now()}.${file.type.split("/")[1] || "png"}`,
+            data: reader.result as string,
+            type: file.type,
+          });
+        };
+      });
+      reader.readAsDataURL(file);
+      newFiles.push(await filePromise);
